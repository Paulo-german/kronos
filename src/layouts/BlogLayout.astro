---
import BaseLayout from "./BaseLayout.astro";
import Navbar from "../components/blocks/Navbar.astro";
import Footer from "../components/blocks/Footer.astro";
import { getCollection } from "astro:content";

interface Props {
  title: string;
  description: string;
  pubDate: Date | undefined;
  updatedDate: Date | undefined;
  heroImage: string | undefined;
  categories: string[];
  seoTitle: string | undefined;
  seoDescription: string | undefined;
  authorName: string;
  authorRole: string;
  authorBio: string;
  authorInitials: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  categories,
  seoTitle,
  seoDescription,
  authorName,
  authorRole,
  authorBio,
  authorInitials,
} = Astro.props;

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("pt-BR", {
    day: "numeric",
    month: "long",
    year: "numeric",
  }).format(date);

const allPosts = await getCollection("blog");
const relatedPosts = allPosts
  .filter((p) => p.data.title !== title && p.data.status === "published")
  .sort((a, b) => (b.data.pubDate?.valueOf() ?? 0) - (a.data.pubDate?.valueOf() ?? 0))
  .slice(0, 3);

const shareUrl = Astro.url.href;
const shareText = encodeURIComponent(title);
const shareUrlEncoded = encodeURIComponent(shareUrl);
---

<BaseLayout title={`${seoTitle ?? title} — Blog Kronos`} description={seoDescription ?? description}>
  <Navbar />
  <main class="blog-post-page">
    <!-- Breadcrumbs -->
    <div class="breadcrumbs-bar">
      <div class="container-narrow">
        <nav class="breadcrumbs" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span class="sep">/</span>
          <a href="/blog">Blog</a>
          <span class="sep">/</span>
          <span class="current">{title.length > 50 ? title.slice(0, 50) + "…" : title}</span>
        </nav>
      </div>
    </div>

    <!-- Header do Post -->
    <header class="post-header">
      <div class="container-narrow">
        <div class="header-content reveal">
          {categories.length > 0 && (
            <div class="categories-row">
              {categories.map((cat) => (
                <span class="category-badge">{cat}</span>
              ))}
            </div>
          )}
          <h1>{title}</h1>
          <p class="post-subtitle">{description}</p>

          <div class="author-row">
            <div class="author-avatar">{authorInitials}</div>
            <div class="author-info">
              <span class="author-name">{authorName}</span>
              <div class="meta-row">
                {pubDate && <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>}
                {updatedDate && (
                  <span class="updated">· Atualizado em {formatDate(updatedDate)}</span>
                )}
              </div>
            </div>
          </div>

          <!-- Share buttons -->
          <div class="share-bar">
            <span class="share-label">Compartilhar:</span>
            <div class="share-buttons">
              <a href={`https://wa.me/?text=${shareText}%20${shareUrlEncoded}`} id="share-whatsapp-blog" data-tracking="cta" data-cta-action="share-whatsapp" data-cta-context="blog" target="_blank" rel="noopener" class="share-btn whatsapp" aria-label="Compartilhar no WhatsApp">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              </a>
              <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${shareUrlEncoded}`} id="share-linkedin-blog" data-tracking="cta" data-cta-action="share-linkedin" data-cta-context="blog" target="_blank" rel="noopener" class="share-btn linkedin" aria-label="Compartilhar no LinkedIn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
              <a href={`https://twitter.com/intent/tweet?text=${shareText}&url=${shareUrlEncoded}`} id="share-twitter-blog" data-tracking="cta" data-cta-action="share-twitter" data-cta-context="blog" target="_blank" rel="noopener" class="share-btn twitter" aria-label="Compartilhar no X">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
              <button class="share-btn copy-link" id="share-copy-blog" data-tracking="cta" data-cta-action="share-copy" data-cta-context="blog" aria-label="Copiar link" data-url={shareUrl}>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
              </button>
            </div>
          </div>
        </div>
      </div>
    </header>

    {heroImage && (
      <div class="hero-image-wrapper">
        <div class="container-narrow">
          <div class="post-hero-img reveal">
            <img src={heroImage} alt={title} />
          </div>
        </div>
      </div>
    )}

    <!-- Conteúdo do Post -->
    <div class="post-body">
      <div class="container-narrow">
        <div class="post-layout">
          <!-- Artigo -->
          <article class="post-content" id="post-content">
            <slot />
          </article>

          <!-- Sidebar TOC (desktop) -->
          <aside class="post-sidebar" id="post-sidebar">
            <div class="toc-wrapper">
              <div class="toc-title">Neste artigo</div>
              <nav class="toc-nav" id="toc-nav">
                <!-- Preenchido por JS -->
              </nav>
            </div>
          </aside>
        </div>
      </div>
    </div>

    <!-- Author Box -->
    <section class="author-box-section">
      <div class="container-narrow">
        <div class="author-box reveal">
          <div class="author-box-avatar">{authorInitials}</div>
          <div class="author-box-info">
            <div class="author-box-label">Escrito por</div>
            <div class="author-box-name">{authorName}</div>
            <div class="author-box-role">{authorRole}</div>
            <p class="author-box-bio">{authorBio}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="post-cta-section">
      <div class="container-narrow">
        <div class="post-cta reveal">
          <div class="post-cta-content">
            <h3>Pronto para vender mais?</h3>
            <p>Veja como IA + CRM + WhatsApp transformam suas vendas.</p>
          </div>
          <a href="https://app.kronoshub.com.br/sign-up" id="cta-comecar-blog" class="btn btn-primary" data-tracking="cta" data-cta-action="sign-up" data-cta-context="blog">COMECE AGORA</a>
        </div>
      </div>
    </section>

    <!-- Posts Relacionados -->
    {relatedPosts.length > 0 && (
      <section class="related-section">
        <div class="container-narrow">
          <h2 class="related-title reveal">Leia também</h2>
          <div class="related-grid">
            {relatedPosts.map((rp, i) => (
              <a
                href={`/blog/${rp.id.replace(/\.mdx?$/, "")}`}
                class={`related-card reveal ${i > 0 ? `reveal-delay-${i}` : ""}`}
              >
                <time datetime={rp.data.pubDate?.toISOString()}>
                  {rp.data.pubDate ? formatDate(rp.data.pubDate) : ""}
                </time>
                <h3>{rp.data.title}</h3>
                <span class="related-link">
                  Ler artigo
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
                </span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Base ── */
  .blog-post-page {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    background: var(--dark);
  }

  .container-narrow {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* ── Breadcrumbs ── */
  .breadcrumbs-bar {
    padding: 100px 0 0;
    background: var(--dark);
  }

  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 13px;
    flex-wrap: wrap;
  }

  .breadcrumbs a {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumbs a:hover {
    color: #8257e5;
  }

  .breadcrumbs .sep {
    color: var(--text-muted);
    opacity: 0.4;
  }

  .breadcrumbs .current {
    color: var(--text-secondary);
  }

  /* ── Header ── */
  .post-header {
    padding: 40px 0 32px;
    background: var(--dark);
  }

  .header-content {
    max-width: 760px;
  }

  .categories-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 20px;
  }

  .category-badge {
    display: inline-block;
    background: rgba(130, 87, 229, 0.15);
    color: #8257e5;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    padding: 5px 14px;
    border-radius: 6px;
  }

  .post-header h1 {
    font-family: var(--font-display);
    font-size: clamp(30px, 4.5vw, 44px);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin-bottom: 16px;
    line-height: 1.15;
  }

  .post-subtitle {
    font-family: var(--font-body);
    font-size: 18px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 32px;
    max-width: 640px;
  }

  /* Author row */
  .author-row {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 24px;
  }

  .author-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: linear-gradient(135deg, #8257e5 0%, #00b37e 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 700;
    color: #fff;
    flex-shrink: 0;
  }

  .author-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .author-name {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
  }

  .meta-row {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--text-muted);
  }

  .updated {
    color: var(--text-muted);
  }

  /* Share bar */
  .share-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-top: 20px;
    border-top: 1px solid var(--dark-3);
  }

  .share-label {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--text-muted);
    font-weight: 500;
  }

  .share-buttons {
    display: flex;
    gap: 8px;
  }

  .share-btn {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: var(--dark-2);
    border: 1px solid var(--dark-3);
    color: var(--text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .share-btn:hover {
    color: var(--text-primary);
    border-color: var(--dark-4);
  }

  .share-btn.whatsapp:hover { color: #25d366; border-color: rgba(37, 211, 102, 0.3); }
  .share-btn.linkedin:hover { color: #0077b5; border-color: rgba(0, 119, 181, 0.3); }
  .share-btn.twitter:hover { color: var(--text-primary); border-color: var(--dark-4); }
  .share-btn.copy-link:hover { color: #8257e5; border-color: rgba(130, 87, 229, 0.3); }

  /* ── Hero Image ── */
  .hero-image-wrapper {
    padding-bottom: 40px;
    background: var(--dark);
  }

  .post-hero-img {
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--dark-3);
  }

  .post-hero-img img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Post Body Layout ── */
  .post-body {
    padding-bottom: 64px;
    background: var(--dark);
  }

  .post-layout {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: 64px;
    align-items: start;
  }

  /* ── Content (prose) ── */
  .post-content {
    font-family: var(--font-body);
    font-size: 17px;
    color: var(--text-secondary);
    line-height: 1.85;
    max-width: 760px;
  }

  .post-content :global(h2) {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 700;
    color: var(--text-primary);
    margin-top: 56px;
    margin-bottom: 20px;
    letter-spacing: -0.02em;
    line-height: 1.25;
    scroll-margin-top: 100px;
  }

  .post-content :global(h3) {
    font-family: var(--font-display);
    font-size: 21px;
    font-weight: 600;
    color: var(--text-primary);
    margin-top: 40px;
    margin-bottom: 14px;
    scroll-margin-top: 100px;
  }

  .post-content :global(p) {
    margin-bottom: 20px;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: 20px;
    padding-left: 28px;
  }

  .post-content :global(li) {
    margin-bottom: 10px;
    padding-left: 4px;
  }

  .post-content :global(li::marker) {
    color: #8257e5;
  }

  .post-content :global(a) {
    color: #8257e5;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(130, 87, 229, 0.3);
    transition: all 0.2s ease;
  }

  .post-content :global(a:hover) {
    color: #996dff;
    text-decoration-color: #996dff;
  }

  .post-content :global(strong) {
    color: var(--text-primary);
    font-weight: 600;
  }

  .post-content :global(blockquote) {
    border-left: 4px solid #8257e5;
    padding: 16px 24px;
    margin: 32px 0;
    background: rgba(130, 87, 229, 0.06);
    border-radius: 0 12px 12px 0;
    color: var(--text-secondary);
    font-style: italic;
  }

  .post-content :global(blockquote p) {
    margin-bottom: 0;
  }

  .post-content :global(code) {
    background: var(--dark-2);
    border: 1px solid var(--dark-3);
    padding: 2px 8px;
    border-radius: 6px;
    font-size: 14px;
    color: var(--text-primary);
  }

  .post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--dark-3);
    margin: 40px 0;
  }

  .post-content :global(img) {
    border-radius: 12px;
    border: 1px solid var(--dark-3);
    margin: 24px 0;
    max-width: 100%;
  }

  /* ── Sidebar TOC ── */
  .post-sidebar {
    position: sticky;
    top: 100px;
  }

  .toc-wrapper {
    background: var(--dark-2);
    border: 1px solid var(--dark-3);
    border-radius: 12px;
    padding: 24px;
  }

  .toc-title {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--dark-3);
  }

  .toc-nav :global(a) {
    display: block;
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--text-muted);
    text-decoration: none;
    padding: 6px 0;
    border-left: 2px solid transparent;
    padding-left: 12px;
    transition: all 0.2s ease;
    line-height: 1.4;
  }

  .toc-nav :global(a:hover),
  .toc-nav :global(a.active) {
    color: #8257e5;
    border-left-color: #8257e5;
  }

  .toc-nav :global(a.toc-h3) {
    padding-left: 24px;
    font-size: 12px;
  }

  /* ── Author Box ── */
  .author-box-section {
    padding: 0 0 64px;
    background: var(--dark);
  }

  .author-box {
    display: flex;
    gap: 24px;
    align-items: flex-start;
    background: var(--dark-2);
    border: 1px solid var(--dark-3);
    border-radius: 16px;
    padding: 32px;
  }

  .author-box-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: linear-gradient(135deg, #8257e5 0%, #00b37e 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    color: #fff;
    flex-shrink: 0;
  }

  .author-box-label {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 4px;
  }

  .author-box-name {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 4px;
  }

  .author-box-role {
    font-family: var(--font-body);
    font-size: 13px;
    color: #8257e5;
    font-weight: 500;
    margin-bottom: 8px;
  }

  .author-box-bio {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* ── CTA ── */
  .post-cta-section {
    padding: 0 0 64px;
    background: var(--dark);
  }

  .post-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    background: linear-gradient(135deg, rgba(130, 87, 229, 0.15) 0%, rgba(0, 179, 126, 0.1) 100%);
    border: 1px solid rgba(130, 87, 229, 0.25);
    border-radius: 16px;
    padding: 40px;
  }

  .post-cta h3 {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 8px;
    letter-spacing: -0.01em;
  }

  .post-cta p {
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .post-cta .btn {
    flex-shrink: 0;
  }

  /* ── Related Posts ── */
  .related-section {
    padding: 64px 0 80px;
    background: var(--dark);
    border-top: 1px solid var(--dark-3);
  }

  .related-title {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 32px;
    letter-spacing: -0.02em;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(280px, 100%), 1fr));
    gap: 24px;
  }

  .related-card {
    background: var(--dark-2);
    border: 1px solid var(--dark-3);
    border-radius: 16px;
    padding: 28px;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }

  .related-card:hover {
    border-color: rgba(130, 87, 229, 0.35);
    box-shadow: 0 8px 32px rgba(130, 87, 229, 0.1);
    transform: translateY(-2px);
  }

  .related-card time {
