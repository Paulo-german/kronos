---
import BaseLayout from "./BaseLayout.astro";
import Navbar from "../components/blocks/Navbar.astro";
import Footer from "../components/blocks/Footer.astro";

interface Props {
  title: string;
  description: string;
  lastUpdated?: string;
}

const { title, description, lastUpdated } = Astro.props;
---

<BaseLayout title={`${title} — Kronos Hub`} description={description}>
  <Navbar />
  <main class="legal-page">
    <div class="legal-container">
      <header class="legal-header reveal">
        <h1>{title}</h1>
        {lastUpdated && (
          <p class="legal-updated">Última atualização: {lastUpdated}</p>
        )}
      </header>
      <article class="legal-content">
        <slot />
      </article>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .legal-page {
    padding: 140px 0 80px;
    position: relative;
    z-index: 1;
    min-height: 100vh;
    background: var(--dark);
  }

  .legal-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .legal-header {
    margin-bottom: 48px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--dark-3);
  }

  .legal-header h1 {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: 12px;
    line-height: 1.2;
  }

  .legal-updated {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text-muted);
  }

  /* ===== Prose styles for legal content ===== */
  .legal-content {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--text-secondary);
    line-height: 1.8;
  }

  .legal-content :global(h2) {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 600;
    color: var(--text-primary);
    margin-top: 48px;
    margin-bottom: 16px;
    letter-spacing: -0.01em;
  }

  .legal-content :global(h3) {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 600;
    color: var(--text-primary);
    margin-top: 32px;
    margin-bottom: 12px;
  }

  .legal-content :global(h4) {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 600;
    color: var(--text-primary);
    margin-top: 24px;
    margin-bottom: 8px;
  }

  .legal-content :global(p) {
    margin-bottom: 16px;
  }

  .legal-content :global(ul),
  .legal-content :global(ol) {
    margin-bottom: 16px;
    padding-left: 24px;
  }

  .legal-content :global(li) {
    margin-bottom: 8px;
  }

  .legal-content :global(a) {
    color: #8257e5;
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s ease;
  }

  .legal-content :global(a:hover) {
    color: #996dff;
  }

  .legal-content :global(strong) {
    color: var(--text-primary);
    font-weight: 600;
  }

  .legal-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 24px 0;
    font-size: 14px;
  }

  .legal-content :global(th),
  .legal-content :global(td) {
    padding: 12px 16px;
    border: 1px solid var(--dark-3);
    text-align: left;
  }

  .legal-content :global(th) {
    background: var(--dark-2);
    color: var(--text-primary);
    font-weight: 600;
  }

  .legal-content :global(blockquote) {
    border-left: 3px solid #8257e5;
    padding-left: 20px;
    margin: 24px 0;
    color: var(--text-secondary);
    font-style: italic;
  }

  .legal-content :global(hr) {
    border: none;
    border-top: 1px solid var(--dark-3);
    margin: 32px 0;
  }

  .legal-content :global(code) {
    background: var(--dark-2);
    border: 1px solid var(--dark-3);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 13px;
    color: var(--text-primary);
  }

  @media (max-width: 640px) {
    .legal-page {
      padding: 100px 0 48px;
    }

    .legal-container {
      padding: 0 16px;
    }

    .legal-header {
      margin-bottom: 32px;
      padding-bottom: 24px;
    }

    .legal-content {
      font-size: 15px;
    }

    .legal-content :global(h2) {
      font-size: 20px;
      margin-top: 36px;
    }

    .legal-content :global(h3) {
      font-size: 18px;
    }
  }
</style>
