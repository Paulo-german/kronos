---
---

<section class="integrations-section" id="integracoes">
  <div class="container">
    <div class="integrations-layout">
      <div class="integrations-content reveal">
        <div class="section-badge">Integrações</div>
        <h2 class="integrations-title">
          Conecta com as ferramentas<br/>
          que voce <span class="gradient-text">ja usa.</span>
        </h2>
        <p class="integrations-desc">
          Conecte-se facilmente com WhatsApp, Stripe, n8n e Typebot. Seus dados fluem automaticamente entre sistemas, sem complicação.
        </p>
        <ul class="integrations-features">
          <li>
            <span class="check-icon">?</span>
            Avisos automaticos em tempo real
          </li>
          <li>
            <span class="check-icon">?</span>
            Integração nativa com Supabase
          </li>
          <li>
            <span class="check-icon">?</span>
            Exportação de dados (planilha e outros formatos)
          </li>
          <li>
            <span class="check-icon">?</span>
            Ferramentas de integracao documentadas
          </li>
        </ul>
        <a href="#" class="btn-api" id="btn-docs">
          <span>{"</>"}</span>
          Ver Documentação da API
        </a>
      </div>

      <div class="integrations-visual reveal reveal-delay-2">
        <!-- Integration grid -->
        <div class="integrations-grid">
          <div class="integration-item">
            <div class="int-icon" style="background: rgba(37,211,102,0.12); border-color: rgba(37,211,102,0.25); color: #25D366;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            </div>
            <span class="int-name">WhatsApp</span>
            <span class="int-status connected">Conectado</span>
          </div>
          <div class="integration-item">
            <div class="int-icon" style="background: rgba(99,91,255,0.12); border-color: rgba(99,91,255,0.25); color: #635bff;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.176 17.512c-1.393.753-3.056 1.049-5.068 1.049-4.223 0-6.958-2.128-6.958-6.22 0-4.208 3.12-6.574 7.558-6.574 1.838 0 3.3.435 4.354.992l-1.047 3.321c-1.002-.511-2.224-.863-3.328-.863-1.84 0-2.88 1.002-2.88 2.454 0 1.259.957 2.052 3.012 2.562 2.656.657 4.417 1.849 4.417 4.5 0 2.602-1.996 4.717-5.592 4.717-1.868 0-3.832-.486-5.166-1.222l1.104-3.424c1.192.686 2.822 1.137 4.237 1.137 1.94 0 2.894-.852 2.894-2.247 0-1.428-.973-2.114-3.116-2.617-2.6-.612-4.312-1.868-4.312-4.463C7.284 6.4 9.215 4.223 13.064 4.223c1.942 0 3.847.492 5.093 1.144l-1.005 3.352c-1-.532-2.32-.934-3.523-.934-1.637 0-2.585.836-2.585 2.223 0 1.246.993 1.928 2.923 2.427 2.766.702 4.545 1.956 4.545 4.673 0 2.646-1.921 4.887-5.6 5.82z"/></svg>
            </div>
            <span class="int-name">Stripe</span>
            <span class="int-status connected">Conectado</span>
          </div>
          <div class="integration-item">
            <div class="int-icon" style="background: rgba(234,82,82,0.12); border-color: rgba(234,82,82,0.25); color: #ea5252;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0q-1.976 0-3.848.74-1.872.74-3.235 2.103Q3.553 4.207 2.813 6.08 2.073 7.953 2.073 9.93q0 1.976.74 3.848.74 1.872 2.104 3.235 1.363 1.364 3.235 2.104Q10.024 19.856 12 19.856q1.976 0 3.848-.74 1.872-.74 3.235-2.104 1.364-1.363 2.104-3.235.74-1.872.74-3.848 0-1.977-.74-3.85-.74-1.873-2.104-3.236-1.363-1.364-3.235-2.104Q13.976 0 12 0ZM9.68 15.65h-1.6V8.12H9.42l3.4 4.81h.06V8.12h1.6v7.53h-1.34Zm8.32 8.35L17.55 24l-3.32-3.32 1.4-1.4z"/></svg>
            </div>
            <span class="int-name">n8n</span>
            <span class="int-status connected">Conectado</span>
          </div>
          <div class="integration-item">
            <div class="int-icon" style="background: rgba(130,87,229,0.12); border-color: rgba(130,87,229,0.25); color: #8257e5;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"></path><rect x="4" y="8" width="16" height="12" rx="2"></rect><path d="M2 14h2"></path><path d="M20 14h2"></path><path d="M15 13v2"></path><path d="M9 13v2"></path></svg>
            </div>
            <span class="int-name">Typebot</span>
            <span class="int-status connected">Conectado</span>
          </div>
          <div class="integration-item">
            <div class="int-icon" style="background: rgba(62,207,142,0.12); border-color: rgba(62,207,142,0.25); color: #3ecf8e;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.03l-9-4.88V6.85l9-4.88 9 4.88v9.3l-9 4.88zm-7.66-5.83l7.66 4.15 7.66-4.15v-7.8l-7.66 4.15v5.36l-5.6-3.03v3.32zm7.66-6.19l-7.66-4.15V5.5l7.66 4.15V15.02l5.6 3.03v-3.32l-5.6-3.03V9.01z"/></svg>
            </div>
            <span class="int-name">Supabase</span>
            <span class="int-status connected">Conectado</span>
          </div>
          <div class="integration-item">
            <div class="int-icon" style="background: rgba(24,119,242,0.12); border-color: rgba(24,119,242,0.25); color: #1877f2;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.469h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.469h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </div>
            <span class="int-name">Meta Ads</span>
            <span class="int-status connected">Conectado</span>
          </div>
          <div class="integration-item">
            <div class="int-icon" style="background: rgba(97,218,251,0.12); border-color: rgba(97,218,251,0.25); color: #61dafb;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
            </div>
            <span class="int-name">Webhooks</span>
            <span class="int-status">Ativo</span>
          </div>
          <div class="integration-item">
            <div class="int-icon" style="background: rgba(251,191,36,0.12); border-color: rgba(251,191,36,0.25); color: #fbbf24;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
            </div>
            <span class="int-name">API REST</span>
            <span class="int-status">Ativo</span>
          </div>
          <div class="integration-item integration-more">
            <span>+40 integrações</span>
          </div>
        </div>

        <!-- JSON code preview -->
        <div class="code-card">
          <div class="code-topbar">
            <div class="code-dots">
              <span class="dot dot-red"></span>
              <span class="dot dot-yellow"></span>
              <span class="dot dot-green"></span>
            </div>
            <span class="code-filename">webhook.json</span>
          </div>
          <pre class="code-content"><code>{`{
  `}<span class="json-key">"event"</span>{`: `}<span class="json-str">"deal.won"</span>{`,
  `}<span class="json-key">"deal_id"</span>{`: `}<span class="json-str">"deal_8x9k2m"</span>{`,
  `}<span class="json-key">"value"</span>{`: `}<span class="json-num">12500</span>{`,
  `}<span class="json-key">"contact"</span>{`: `}<span class="json-str">"Paulo German"</span>{`,
  `}<span class="json-key">"stage"</span>{`: `}<span class="json-str">"closed_won"</span>{`
}`}</code></pre>
          <div class="code-badge">
            <span class="live-dot"></span>
            Evento disparado em tempo real
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .integrations-section {
    padding: 80px 0;
  }

  .integrations-layout {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 80px;
    align-items: center;
  }

  .section-badge {
    display: flex;
    width: fit-content;
    margin-left: auto;
    margin-right: auto;
    background: var(--dark-2);
    border: 1px solid var(--dark-3);
    color: white;
    font-size: 12px;
    font-family: var(--font-body);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
    padding: 6px 16px;
    border-radius: 8px;
    margin-bottom: 20px;
  }

  .integrations-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 36px);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 20px;
  }

  .integrations-desc {
    font-family: var(--font-display);
    font-size: 16px;
    color: rgba(255,255,255,0.5);
    line-height: 1.7;
    margin-bottom: 32px;
  }

  .integrations-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 36px;
  }

  .integrations-features li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-size: 15px;
    color: rgba(255,255,255,0.75);
    font-weight: 500;
  }

  .check-icon {
    width: 20px;
    height: 20px;
    background: rgba(130, 87, 229, 0.15);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #8257e5;
    font-size: 11px;
    font-weight: 600;
    flex-shrink: 0;
    text-align: center;
    line-height: 20px;
  }

  .btn-api {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    border: 1px solid rgba(130, 87, 229, 0.35);
    color: rgba(255,255,255,0.85);
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    padding: 12px 22px;
    border-radius: 8px;
    transition: all 0.2s ease;
    font-family: var(--font-body);
  }

  .btn-api:hover {
    border-color: rgba(130, 87, 229, 0.7);
    background: rgba(130, 87, 229, 0.08);
    color: white;
  }

  .btn-api span {
    color: #8257e5;
    font-weight: 600;
  }

  /* Integration grid */
  .integrations-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin-bottom: 20px;
  }

  .integration-item {
    background: var(--dark-2);
    border: 1px solid var(--dark-3);
    border-radius: 16px;
    padding: 14px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-align: center;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .integration-item:hover {
    background: rgba(130,87,229,0.06);
    border-color: rgba(130,87,229,0.2);
  }

  .integration-more {
    border-style: dashed;
    color: rgba(255,255,255,0.3);
    font-size: 11px;
    font-weight: 500;
    justify-content: center;
    padding: 14px 8px;
    background: transparent;
  }

  .int-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    border: 1px solid;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
  }

  .int-name {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 500;
    color: rgba(255,255,255,0.4);
  }

  .int-status {
    font-size: 9px;
    font-weight: 500;
    padding: 2px 7px;
    border-radius: 100px;
    background: rgba(97,218,251,0.1);
    color: #61dafb;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .int-status.connected {
    background: rgba(74,222,128,0.1);
    color: #4ade80;
  }

  /* Code card */
  .code-card {
    background: rgba(10,10,18,0.95);
    border: 1px solid var(--dark-3);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
  }

  .code-topbar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--dark-3);
    background: rgba(0,0,0,0.3);
  }

  .code-dots {
    display: flex;
    gap: 5px;
  }

  .dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
  }

  .dot-red { background: #ff5f57; }
  .dot-yellow { background: #ffbd2e; }
  .dot-green { background: #28c840; }

  .code-filename {
    flex: 1;
    text-align: center;
    font-size: 11px;
    color: rgba(255,255,255,0.4);
    font-weight: 500;
    font-family: var(--font-body);
  }

  .code-content {
    padding: 20px;
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.8;
    color: rgba(255,255,255,0.4);
  }

  .json-key { color: #996dff; }
  .json-str { color: #61dafb; }
  .json-num { color: #fbbf24; }

  .code-badge {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 12px 16px;
    border-top: 1px solid var(--dark-3);
    font-size: 11px;
    font-weight: 500;
    color: #4ade80;
    background: rgba(74,222,128,0.05);
  }

  .live-dot {
    width: 6px;
    height: 6px;
    background: #4ade80;
    border-radius: 50%;
    box-shadow: 0 0 8px #4ade80;
    animation: live-pulse 1.5s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes live-pulse {
    0%, 100% { box-shadow: 0 0 4px #4ade80; }
    50% { box-shadow: 0 0 15px #4ade80; }
  }

  .gradient-text { color: #ffffff; }

  @media (max-width: 1024px) {
    .integrations-layout {
      grid-template-columns: 1fr;
      gap: 60px;
    }
  }

  @media (max-width: 480px) {
    .integrations-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
