---
import logoLegacy from "../../../logo-clientes/logo-legacy.webp";
import logoMaluMake from "../../../logo-clientes/logo-malumake.webp";
import logoBraganca from "../../../logo-clientes/logo-bragançaadvogados.webp";

interface VideoTestimonial {
  vimeoId: string;
  name: string;
  role: string;
  company: string;
  logo?: ImageMetadata;
}

const videos: VideoTestimonial[] = [
  {
    vimeoId: "1176021709",
    name: "Rafael Ramos",
    role: "Dono e CEO",
    company: "Legacy School",
    logo: logoLegacy,
  },
  {
    vimeoId: "1176022820",
    name: "Maria Luísa",
    role: "Dona e CEO",
    company: "Malu Make",
    logo: logoMaluMake,
  },
  {
    vimeoId: "1176025418",
    name: "Heloísa Bragança",
    role: "Advogada e CEO",
    company: "Bragança Advogados",
    logo: logoBraganca,
  },
];
---

<section class="video-testimonials-section" id="depoimentos-video">
  <div class="container">
    <div class="section-header reveal">
      <div class="section-badge">Depoimentos em Vídeo</div>
      <h2 class="section-title">
        Veja quem já está <span class="gradient-text">transformando resultados</span>
      </h2>
      <p class="section-desc">
        Histórias reais de clientes que escalaram suas operações com a Kronos.
      </p>
    </div>

    <div class="videos-grid">
      {videos.map((v, i) => (
        <div class={`video-card reveal ${i > 0 ? `reveal-delay-${Math.min(i, 4)}` : ""}`}>
          <div class="video-wrapper">
            <iframe
              src={`https://player.vimeo.com/video/${v.vimeoId}?badge=0&autopause=0&player_id=0&app_id=58479&title=0&byline=0&portrait=0&transparent=0&pip=0`}
              frameborder="0"
              allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media"
              allowfullscreen
              title={`Depoimento de ${v.name}`}
              loading="lazy"
            ></iframe>
            <!-- Bloqueia clique na logo Vimeo (canto inferior esquerdo) -->
            <div class="vimeo-logo-block" aria-hidden="true"></div>
          </div>

          <!-- Info do autor -->
          <div class="video-info">
            <!-- Linha 1: empresa em destaque -->
            <div class="video-company-row">
              {v.logo ? (
                <div class="video-company-logo">
                  <img src={v.logo.src} alt={`Logo ${v.company}`} />
                </div>
              ) : null}
              <div class="video-company-name">{v.company}</div>
              <div class="video-stars">★★★★★</div>
            </div>
            <!-- Linha 2: pessoa -->
            <div class="video-person-row">
              {!v.logo && (
                <div class="video-author-avatar">{v.name.charAt(0)}</div>
              )}
              <div class="video-author-text">
                <div class="video-author-name">{v.name}</div>
                <div class="video-author-role">{v.role}</div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>



<style>
  .video-testimonials-section {
    padding: 80px 0;
    background: var(--dark-2);
    border-top: 1px solid var(--dark-3);
    border-bottom: 1px solid var(--dark-3);
  }

  /* ── Header ── */
  .section-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .section-badge {
    display: inline-block;
    background: var(--dark-2);
    border: 1px solid var(--dark-3);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
    padding: 6px 16px;
    border-radius: 8px;
    margin-bottom: 20px;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 36px);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
  }

  .section-desc {
    font-family: var(--font-display);
    font-size: 16px;
    color: var(--text-secondary);
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* ── Grid ── */
  .videos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 32px;
    justify-items: center;
  }

  .videos-grid:has(.video-card:only-child) {
    grid-template-columns: minmax(340px, 640px);
  }

  /* ── Card ── */
  .video-card {
    background: var(--dark);
    border: 1px solid var(--dark-3);
    border-radius: 16px;
    overflow: hidden;
    width: 100%;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .video-card:hover {
    border-color: rgba(130, 87, 229, 0.35);
    box-shadow: 0 8px 32px rgba(130, 87, 229, 0.12);
  }

  /* ── Wrapper 16:9 ── */
  .video-wrapper {
    position: relative;
    width: 100%;
    padding-top: 56.25%;
    background: #000;
    border-radius: 16px 16px 0 0;
    overflow: hidden;
  }

  .video-wrapper iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  /* ── Bloqueio da logo Vimeo ── */
  .vimeo-logo-block {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 120px;
    height: 44px;
    z-index: 5;
    cursor: default;
    /* transparente — só bloqueia cliques */
  }

  /* ── Info ──*/
  .video-info {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 16px 20px;
    border-top: 1px solid var(--dark-3);
  }

  .video-company-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .video-company-name {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.01em;
    flex: 1;
  }

  .video-person-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding-top: 8px;
    border-top: 1px solid var(--dark-3);
  }

  .video-author-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, #8257e5 0%, #00b37e 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 700;
    color: #fff;
    flex-shrink: 0;
  }

  .video-company-logo {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4px;
    flex-shrink: 0;
    overflow: hidden;
  }

  .video-company-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .video-author-text { flex: 1; min-width: 0; }

  .video-author-name {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .video-author-role {
    font-family: var(--font-display);
    font-size: 11px;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .video-stars {
    font-size: 13px;
    color: #fbbf24;
    letter-spacing: 1px;
    flex-shrink: 0;
  }

  /* ── Modal ── */
  .vt-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    align-items: center;
    justify-content: center;
    padding: 16px;
  }

  .vt-modal.is-open {
    display: flex;
  }

  .vt-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.88);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    animation: vt-fade-in 0.22s ease;
  }

  .vt-modal-content {
    position: relative;
    width: 100%;
    max-width: 900px;
    z-index: 1;
    animation: vt-slide-up 0.28s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .vt-modal-close {
    position: absolute;
    top: -48px;
    right: 0;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #fff;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .vt-modal-close:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .vt-modal-video-wrapper {
    position: relative;
    width: 100%;
    padding-top: 56.25%;
    border-radius: 16px;
    overflow: hidden;
    background: #000;
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.8);
  }

  .vt-modal-video-wrapper iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  @keyframes vt-fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @keyframes vt-slide-up {
    from { opacity: 0; transform: translateY(30px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* ── Responsivo ── */
  @media (max-width: 640px) {
    .videos-grid,
    .videos-grid:has(.video-card:only-child) {
      grid-template-columns: 1fr;
    }
  }
</style>


