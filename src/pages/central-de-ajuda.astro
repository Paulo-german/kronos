---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/blocks/Navbar.astro";
import Footer from "../components/blocks/Footer.astro";

const categories = [
  {
    icon: "play",
    title: "Primeiros Passos",
    desc: "Como criar sua conta, configurar a organização e adicionar membros ao time.",
  },
  {
    icon: "layout",
    title: "CRM e Funil de Vendas",
    desc: "Gerenciar contatos, empresas, negócios e mover oportunidades pelo funil.",
  },
  {
    icon: "message",
    title: "WhatsApp e Inbox",
    desc: "Conectar seu número, enviar mensagens e gerenciar conversas na inbox.",
  },
  {
    icon: "bot",
    title: "Agente de IA",
    desc: "Configurar o agente, criar base de conhecimento e gerenciar créditos.",
  },
  {
    icon: "credit",
    title: "Pagamentos e Planos",
    desc: "Assinatura, cobrança, upgrade de plano e gerenciamento de créditos de IA.",
  },
  {
    icon: "plug",
    title: "Integrações",
    desc: "Google Calendar, Z-API, Evolution API e outras integrações disponíveis.",
  },
];

const faqs = [
  {
    q: "Como faço para criar minha conta?",
    a: "Acesse app.kronoshub.com.br/sign-up, preencha seus dados e confirme o e-mail. Em menos de 2 minutos você já pode começar a usar.",
  },
  {
    q: "Como começo a usar a Kronos?",
    a: "Acesse app.kronoshub.com.br/sign-up, crie sua conta e comece a usar. Em poucos minutos sua operação de vendas já estará rodando.",
  },
  {
    q: "Como conecto meu WhatsApp à Kronos?",
    a: "Vá em Configurações > WhatsApp e siga o passo a passo para conectar via Meta Cloud API, Evolution API ou Z-API.",
  },
  {
    q: "O que são créditos de IA?",
    a: "Créditos de IA são a unidade de consumo para funcionalidades de inteligência artificial, como respostas automáticas do agente de WhatsApp e resumos de conversas. Cada plano inclui uma franquia mensal.",
  },
  {
    q: "Posso cancelar minha assinatura a qualquer momento?",
    a: "Sim. O cancelamento pode ser feito pelo painel de configurações da organização. O acesso continua até o final do período já pago.",
  },
  {
    q: "Meus dados estão seguros?",
    a: "Sim. Utilizamos criptografia em trânsito e em repouso, isolamento de dados por organização e nosso banco de dados fica hospedado na AWS São Paulo. Para mais detalhes, consulte nossa Política de Privacidade.",
  },
  {
    q: "Como adiciono membros à minha equipe?",
    a: "Vá em Configurações > Equipe e envie um convite por e-mail. Você pode definir o papel de cada membro (Proprietário, Administrador ou Membro).",
  },
  {
    q: "A Kronos funciona no celular?",
    a: "Sim. A Kronos é uma aplicação web responsiva que funciona em qualquer navegador, tanto no desktop quanto no celular.",
  },
];
---

<BaseLayout
  title="Central de Ajuda — Kronos Hub"
  description="Encontre respostas para suas dúvidas sobre a Kronos. Guias, tutoriais e perguntas frequentes."
>
  <Navbar />
  <main>
    <!-- Hero -->
    <section class="help-hero">
      <div class="container">
        <div class="hero-content reveal">
          <div class="section-badge">Central de Ajuda</div>
          <h1>Como podemos <span class="highlight">ajudar?</span></h1>
          <p class="hero-desc">
            Encontre guias, tutoriais e respostas para as dúvidas mais comuns sobre a Kronos.
          </p>
        </div>
      </div>
    </section>

    <!-- Categorias -->
    <section class="categories-section">
      <div class="container">
        <div class="categories-grid">
          {categories.map((cat, i) => (
            <div class={`category-card reveal ${i > 0 ? `reveal-delay-${Math.min(i % 3, 2)}` : ""}`}>
              <div class="category-icon">
                {cat.icon === "play" && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                )}
                {cat.icon === "layout" && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
                )}
                {cat.icon === "message" && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                )}
                {cat.icon === "bot" && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"></path><rect width="16" height="12" x="4" y="8" rx="2"></rect><path d="M2 14h2"></path><path d="M20 14h2"></path><path d="M15 13v2"></path><path d="M9 13v2"></path></svg>
                )}
                {cat.icon === "credit" && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"></rect><line x1="2" y1="10" x2="22" y2="10"></line></svg>
                )}
                {cat.icon === "plug" && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22v-5"></path><path d="M9 8V2"></path><path d="M15 8V2"></path><path d="M18 8v5a6 6 0 0 1-6 6v0a6 6 0 0 1-6-6V8z"></path></svg>
                )}
              </div>
              <h3>{cat.title}</h3>
              <p>{cat.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section">
      <div class="container">
        <div class="section-header reveal">
          <div class="section-badge">FAQ</div>
          <h2>Perguntas frequentes</h2>
        </div>
        <div class="faq-list">
          {faqs.map((faq, i) => (
            <details class={`faq-item reveal ${i > 0 ? `reveal-delay-${Math.min(i % 3, 2)}` : ""}`}>
              <summary>
                <span>{faq.q}</span>
                <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"></path></svg>
              </summary>
              <div class="faq-answer">
                <p>{faq.a}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Contato -->
    <section class="contact-cta-section">
      <div class="container">
        <div class="contact-box reveal">
          <h2>Não encontrou o que procurava?</h2>
          <p>Fale diretamente com nosso time de suporte pelo WhatsApp.</p>
          <a
            href="https://wa.me/5521936184733?text=Ol%C3%A1%2C%20preciso%20de%20ajuda%20com%20a%20Kronos"
            target="_blank"
            rel="noopener"
            id="cta-suporte-ajuda"
            class="btn btn-primary"
            data-tracking="cta" 
            data-cta-action="whatsapp" 
            data-cta-context="central-de-ajuda"
          >
            FALAR COM SUPORTE
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Hero ── */
  .help-hero {
    padding: 160px 0 80px;
    background: var(--dark);
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .hero-content {
    max-width: 720px;
    margin: 0 auto;
  }

  .section-badge {
    display: inline-block;
    background: var(--dark-2);
    border: 1px solid var(--dark-3);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
    padding: 6px 16px;
    border-radius: 8px;
    margin-bottom: 20px;
  }

  .help-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--text-primary);
    margin-bottom: 24px;
  }

  .highlight { color: #8257e5; }

  .hero-desc {
    font-family: var(--font-body);
    font-size: 18px;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .section-header h2 {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 36px);
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  /* ── Categorias ── */
  .categories-section {
    padding: 0 0 80px;
    background: var(--dark);
    position: relative;
    z-index: 1;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .category-card {
    background: var(--dark-2);
    border: 1px solid var(--dark-3);
    border-radius: 16px;
    padding: 32px;
    transition: border-color 0.2s ease;
  }

  .category-card:hover {
    border-color: rgba(130, 87, 229, 0.3);
  }

  .category-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(130, 87, 229, 0.15);
    color: #8257e5;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
  }

  .category-card h3 {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 8px;
  }

  .category-card p {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* ── FAQ ── */
  .faq-section {
    padding: 80px 0;
    background: var(--dark);
    border-top: 1px solid var(--dark-3);
    position: relative;
    z-index: 1;
  }

  .faq-list {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .faq-item {
    background: var(--dark-2);
    border: 1px solid var(--dark-3);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.2s ease;
  }

  .faq-item[open] {
    border-color: rgba(130, 87, 229, 0.3);
  }

  .faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px;
    cursor: pointer;
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 500;
    color: var(--text-primary);
    list-style: none;
    transition: color 0.2s ease;
  }

  .faq-item summary:hover {
    color: #8257e5;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-chevron {
    flex-shrink: 0;
    transition: transform 0.2s ease;
    color: var(--text-muted);
  }

  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
  }

  .faq-answer {
    padding: 0 24px 20px;
  }

  .faq-answer p {
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* ── CTA Contato ── */
  .contact-cta-section {
    padding: 80px 0;
    background: var(--dark);
    position: relative;
    z-index: 1;
  }

  .contact-box {
    text-align: center;
    background: var(--dark-2);
    border: 1px solid var(--dark-3);
    border-radius: 16px;
    padding: 64px 32px;
  }

  .contact-box h2 {
    font-family: var(--font-display);
    font-size: clamp(24px, 4vw, 32px);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }

  .contact-box p {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--text-secondary);
    margin-bottom: 32px;
  }

  /* ── Responsivo ── */
  @media (max-width: 900px) {
    .categories-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .help-hero { padding: 120px 0 48px; }
    .categories-section { padding: 0 0 48px; }
    .faq-section, .contact-cta-section { padding: 48px 0; }
    .categories-grid { grid-template-columns: 1fr; }
    .contact-box { padding: 40px 24px; }
    .faq-item summary { font-size: 15px; padding: 16px 20px; }
  }
</style>
