---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/blocks/Navbar.astro";
import Footer from "../../components/blocks/Footer.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => (b.data.pubDate?.valueOf() ?? 0) - (a.data.pubDate?.valueOf() ?? 0)
);

const formatDate = (date?: Date) =>
  date
    ? new Intl.DateTimeFormat("pt-BR", {
        day: "numeric",
        month: "long",
        year: "numeric",
      }).format(date)
    : "";
---

<BaseLayout
  title="Blog — Kronos Hub"
  description="Artigos sobre vendas, CRM, inteligência artificial e WhatsApp Business. Dicas práticas para vender mais e melhor."
>
  <Navbar />
  <main>
    <!-- Hero -->
    <section class="blog-hero">
      <div class="container">
        <div class="hero-content reveal">
          <div class="section-badge">Blog</div>
          <h1>
            Insights para <span class="highlight">vender mais</span>
          </h1>
          <p class="hero-desc">
            Artigos sobre vendas, CRM, IA e WhatsApp Business para ajudar sua empresa a crescer.
          </p>
        </div>
      </div>
    </section>

    <!-- Posts Grid -->
    <section class="posts-section">
      <div class="container">
        <div class="posts-grid">
          {posts.map((post, i) => (
            <a
              href={`/blog/${post.id.replace(/\.mdx?$/, "")}`}
              class={`post-card reveal ${i > 0 ? `reveal-delay-${Math.min(i, 2)}` : ""}`}
            >
              <div class="post-card-content">
                <time datetime={post.data.pubDate?.toISOString()}>
                  {formatDate(post.data.pubDate)}
                </time>
                <h2>{post.data.title}</h2>
                <p>{post.data.description}</p>
                <span class="read-more">
                  Ler artigo
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
                </span>
              </div>
            </a>
          ))}
        </div>

        {posts.length === 0 && (
          <div class="no-posts">
            <p>Nenhum artigo publicado ainda. Volte em breve!</p>
          </div>
        )}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Hero ── */
  .blog-hero {
    padding: 160px 0 80px;
    background: var(--dark);
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .hero-content {
    max-width: 720px;
    margin: 0 auto;
  }

  .section-badge {
    display: inline-block;
    background: var(--dark-2);
    border: 1px solid var(--dark-3);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
    padding: 6px 16px;
    border-radius: 8px;
    margin-bottom: 20px;
  }

  .blog-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--text-primary);
    margin-bottom: 24px;
  }

  .highlight { color: #8257e5; }

  .hero-desc {
    font-family: var(--font-body);
    font-size: 18px;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto;
  }

  /* ── Posts ── */
  .posts-section {
    padding: 0 0 80px;
    background: var(--dark);
    position: relative;
    z-index: 1;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(340px, 100%), 1fr));
    gap: 24px;
  }

  .post-card {
    background: var(--dark-2);
    border: 1px solid var(--dark-3);
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
    display: flex;
    flex-direction: column;
  }

  .post-card:hover {
    border-color: rgba(130, 87, 229, 0.35);
    box-shadow: 0 8px 32px rgba(130, 87, 229, 0.1);
    transform: translateY(-2px);
  }

  .post-card-content {
    padding: 32px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .post-card time {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 16px;
  }

  .post-card h2 {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.01em;
    line-height: 1.3;
    margin-bottom: 12px;
  }

  .post-card p {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.7;
    flex: 1;
    margin-bottom: 20px;
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    color: #8257e5;
    margin-top: auto;
    transition: gap 0.2s ease;
  }

  .post-card:hover .read-more {
    gap: 10px;
  }

  .no-posts {
    text-align: center;
    padding: 64px 32px;
    color: var(--text-muted);
  }

  /* ── Responsivo ── */
  @media (max-width: 640px) {
    .blog-hero { padding: 120px 0 48px; }
    .posts-section { padding: 0 0 48px; }
    .post-card-content { padding: 24px; }
  }
</style>
