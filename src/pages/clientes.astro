---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/blocks/Navbar.astro";
import Footer from "../components/blocks/Footer.astro";
import { getEntry } from "astro:content";

import logoLegacy from "../assets/logo-clientes/logo-legacy.webp";
import logoMaluMake from "../assets/logo-clientes/logo-malumake.webp";
import logoBraganca from "../assets/logo-clientes/logo-bragançaadvogados.webp";

const entry = await getEntry("clients", "data");
const { testimonials, companies, caseStudy, metrics } = entry.data;

const videos = [
  {
    vimeoId: "1176021709",
    name: "Rafael Ramos",
    role: "Dono e CEO",
    company: "Legacy School",
    logo: logoLegacy,
  },
  {
    vimeoId: "1176022820",
    name: "Maria Luísa",
    role: "Dona e CEO",
    company: "Malu Make",
    logo: logoMaluMake,
  },
  {
    vimeoId: "1176025418",
    name: "Heloísa Bragança",
    role: "Advogada e CEO",
    company: "Bragança Advogados",
    logo: logoBraganca,
  },
];

const stars = "★★★★★";
---

<BaseLayout
  title="Clientes — Kronos Hub"
  description="Conheça as empresas que já vendem mais com a Kronos. Depoimentos reais, cases de sucesso e resultados comprovados."
>
  <Navbar />
  <main>
    <!-- Hero -->
    <section class="clients-hero">
      <div class="container">
        <div class="hero-content reveal">
          <div class="section-badge">Nossos clientes</div>
          <h1>
            Empresas que <span class="highlight">vendem mais</span> com a Kronos
          </h1>
          <p class="hero-desc">
            De escritórios de advocacia a clínicas, de academias a imobiliárias — mais de 120 empresas já transformaram suas vendas.
          </p>
        </div>
      </div>
    </section>

    <!-- Logos -->
    <section class="logos-section">
      <div class="container">
        <div class="logos-grid reveal">
          {companies.map((c) => (
            <div class="logo-item">
              <span class="logo-name">{c.name}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Métricas -->
    <section class="metrics-section">
      <div class="container">
        <div class="metrics-grid">
          {metrics.map((m, i) => (
            <div class={`metric-item reveal ${i > 0 ? `reveal-delay-${i}` : ""}`}>
              <div class="metric-number">{m.prefix || ""}{m.target}{m.suffix}</div>
              <div class="metric-label">{m.label}</div>
              <div class="metric-desc">{m.description}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Depoimentos em vídeo -->
    <section class="video-section">
      <div class="container">
        <div class="section-header reveal">
          <div class="section-badge">Na prática</div>
          <h2>Quem usa, <span class="highlight">não volta atrás</span></h2>
          <p class="section-desc">Donos de empresa e gestores comerciais contam como a Kronos mudou a operação deles.</p>
        </div>
        <div class="videos-grid">
          {videos.map((v, i) => (
            <div class={`video-card reveal ${i > 0 ? `reveal-delay-${i}` : ""}`}>
              <div class="video-wrapper">
                <iframe
                  src={`https://player.vimeo.com/video/${v.vimeoId}?badge=0&autopause=0&player_id=0&app_id=58479&title=0&byline=0&portrait=0&transparent=0&pip=0`}
                  frameborder="0"
                  allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media"
                  allowfullscreen
                  title={`Depoimento de ${v.name}`}
                  loading="lazy"
                ></iframe>
              </div>
              <div class="video-info">
                <div class="video-company-row">
                  {v.logo && (
                    <div class="video-company-logo">
                      <img src={v.logo.src} alt={`Logo ${v.company}`} />
                    </div>
                  )}
                  <div class="video-company-name">{v.company}</div>
                  <div class="video-stars">★★★★★</div>
                </div>
                <div class="video-person-row">
                  <div class="video-author-text">
                    <div class="video-author-name">{v.name}</div>
                    <div class="video-author-role">{v.role}</div>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Depoimentos em texto -->
    <section class="testimonials-section">
      <div class="container">
        <div class="section-header reveal">
          <div class="section-badge">Depoimentos</div>
          <h2>O que nossos clientes <span class="highlight">dizem</span></h2>
        </div>
        <div class="testimonials-grid">
          {testimonials.map((t, i) => (
            <div class={`testimonial-card reveal ${i > 0 ? `reveal-delay-${Math.min(i % 3, 2)}` : ""}`}>
              <div class="testimonial-quote">"</div>
              <p class="testimonial-text" set:html={t.quote} />
              <div class="testimonial-author">
                <div class="author-avatar" style={`background: ${t.avatarColor};`}>{t.avatarInitials}</div>
                <div class="author-info">
                  <div class="author-name">{t.name}</div>
                  <div class="author-role">{t.role} | {t.company}</div>
                </div>
                <div class="testimonial-stars">{stars.slice(0, t.rating)}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Case Study -->
    <section class="case-section">
      <div class="container">
        <div class="case-study reveal">
          <div class="cs-header">
            <div class="section-badge">Case de sucesso</div>
            <h3 class="cs-title">{caseStudy.company}: {caseStudy.title}</h3>
          </div>
          <div class="cs-metrics">
            {caseStudy.metrics.map((m, i) => (
              <>
                {i > 0 && <div class="cs-divider" />}
                <div class="cs-metric">
                  <div class="csm-value">{m.value}</div>
                  <div class="csm-label">{m.label}</div>
                </div>
              </>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-box reveal">
          <h2>Faça parte desse grupo</h2>
          <p>Comece a vender mais com a Kronos e veja o resultado no primeiro mês.</p>
          <a href="https://app.kronoshub.com.br/sign-up" id="cta-comecar-clientes" class="btn btn-primary" data-tracking="cta" data-cta-action="sign-up" data-cta-context="clientes">COMEÇAR AGORA</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  /* ── Hero ── */
  .clients-hero {
    padding: 160px 0 80px;
    background: var(--dark);
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .hero-content {
    max-width: 720px;
    margin: 0 auto;
  }

  .section-badge {
    display: inline-block;
    background: var(--dark-2);
    border: 1px solid var(--dark-3);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
    padding: 6px 16px;
    border-radius: 8px;
    margin-bottom: 20px;
  }

  .clients-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--text-primary);
    margin-bottom: 24px;
  }

  .highlight { color: #8257e5; }

  .hero-desc {
    font-family: var(--font-body);
    font-size: 18px;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .section-header h2 {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 36px);
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    margin-bottom: 16px;
  }

  .section-desc {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--text-secondary);
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* ── Logos ── */
  .logos-section {
    padding: 60px 0;
    background: var(--dark);
    border-top: 1px solid var(--dark-3);
    position: relative;
    z-index: 1;
  }

  .logos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 16px;
  }

  .logo-item {
    background: var(--dark-2);
    border: 1px solid var(--dark-3);
    border-radius: 12px;
    padding: 24px 16px;
    text-align: center;
    transition: border-color 0.2s ease;
  }

  .logo-item:hover {
    border-color: rgba(130, 87, 229, 0.3);
  }

  .logo-name {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  /* ── Métricas ── */
  .metrics-section {
    padding: 80px 0;
    background: var(--dark);
    border-top: 1px solid var(--dark-3);
    border-bottom: 1px solid var(--dark-3);
    position: relative;
    z-index: 1;
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
  }

  .metric-item {
    padding: 32px 40px;
    border-right: 1px solid var(--dark-3);
    text-align: center;
    transition: background 0.2s ease;
  }

  .metric-item:last-child { border-right: none; }
  .metric-item:hover { background: rgba(130, 87, 229, 0.05); }

  .metric-number {
    font-family: var(--font-display);
    font-size: clamp(28px, 5vw, 42px);
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }

  .metric-label {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 6px;
  }

  .metric-desc {
    font-family: var(--font-display);
    font-size: 11px;
    color: var(--text-muted);
  }

  /* ── Vídeos ── */
  .video-section {
    padding: 80px 0;
    background: var(--dark);
    border-bottom: 1px solid var(--dark-3);
    position: relative;
    z-index: 1;
  }

  .videos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(300px, 100%), 1fr));
    gap: 24px;
  }

  .video-card {
    background: var(--dark);
    border: 1px solid var(--dark-3);
    border-radius: 16px;
    overflow: hidden;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .video-card:hover {
    border-color: rgba(130, 87, 229, 0.35);
    box-shadow: 0 8px 32px rgba(130, 87, 229, 0.12);
  }

  .video-wrapper {
    position: relative;
    width: 100%;
    padding-top: 56.25%;
    background: #000;
  }

  .video-wrapper iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .video-info {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 16px 20px;
    border-top: 1px solid var(--dark-3);
  }

  .video-company-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .video-company-logo {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4px;
    flex-shrink: 0;
    overflow: hidden;
  }

  .video-company-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .video-company-name {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 700;
    color: var(--text-primary);
    flex: 1;
  }

  .video-stars {
    font-size: 13px;
    color: #fbbf24;
    letter-spacing: 1px;
    flex-shrink: 0;
  }

  .video-person-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding-top: 8px;
    border-top: 1px solid var(--dark-3);
  }

  .video-author-text { flex: 1; }

  .video-author-name {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 2px;
  }

  .video-author-role {
    font-family: var(--font-display);
    font-size: 11px;
    color: var(--text-muted);
  }

  /* ── Depoimentos ── */
  .testimonials-section {
    padding: 80px 0;
    background: var(--dark);
    position: relative;
    z-index: 1;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .testimonial-card {
    background: var(--dark-2);
    border: 1px solid var(--dark-3);
    border-radius: 16px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    text-align: center;
    transition: border-color 0.2s ease;
  }

  .testimonial-card:hover {
    border-color: rgba(130, 87, 229, 0.3);
  }

  .testimonial-quote {
    font-family: "Georgia", serif;
    font-size: 50px;
    line-height: 0.8;
    color: rgba(130, 87, 229, 0.4);
    margin-bottom: 20px;
    font-weight: 600;
  }

  .testimonial-text {
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 28px;
    flex: 1;
  }

  .testimonial-text :global(strong) {
    color: var(--text-primary);
    font-weight: 500;
  }

  .testimonial-author {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    margin-top: auto;
  }

  .author-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
    color: #ffffff;
  }

  .author-name {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 3px;
  }

  .author-role {
    font-family: var(--font-display);
    font-size: 11px;
    color: var(--text-muted);
  }

  .testimonial-stars {
    font-size: 14px;
    color: #fbbf24;
    letter-spacing: 1px;
  }

  /* ── Case Study ── */
  .case-section {
    padding: 80px 0;
    background: var(--dark);
    border-top: 1px solid var(--dark-3);
    position: relative;
    z-index: 1;
  }

  .case-study {
    background: var(--dark-2);
    border: 1px solid var(--dark-3);
    border-radius: 16px;
    padding: 32px;
  }

  .cs-header {
    margin-bottom: 32px;
    text-align: center;
  }

  .cs-title {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 500;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  .cs-metrics {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cs-metric {
    flex: 1;
    text-align: center;
    padding: 0 24px;
  }

  .csm-value {
    font-family: var(--font-display);
    font-size: 40px;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }

  .csm-label {
    font-family: var(--font-display);
    font-size: 13px;
    color: var(--text-secondary);
    font-weight: 500;
  }

  .cs-divider {
    width: 1px;
    height: 60px;
    background: var(--dark-3);
  }

  /* ── CTA ── */
  .cta-section {
    padding: 80px 0;
    background: var(--dark);
    position: relative;
    z-index: 1;
  }

  .cta-box {
    text-align: center;
    background: var(--dark-2);
    border: 1px solid var(--dark-3);
    border-radius: 16px;
    padding: 64px 32px;
  }

  .cta-box h2 {
    font-family: var(--font-display);
    font-size: clamp(24px, 4vw, 32px);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }

  .cta-box p {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--text-secondary);
    margin-bottom: 32px;
  }

  /* ── Responsivo ── */
  @media (max-width: 900px) {
    .testimonials-grid { grid-template-columns: repeat(2, 1fr); }
    .metrics-grid { grid-template-columns: repeat(2, 1fr); }
    .metric-item:nth-child(2) { border-right: none; }
    .cs-metrics { flex-wrap: wrap; }
    .cs-divider { display: none; }
    .cs-metric { min-width: 50%; padding: 12px 0; }
  }

  @media (max-width: 640px) {
    .clients-hero { padding: 120px 0 48px; }
    .logos-section,
    .metrics-section,
    .video-section,
    .testimonials-section,
    .case-section,
    .cta-section {
      padding: 48px 0;
    }
    .testimonials-grid { grid-template-columns: 1fr; }
    .metrics-grid { grid-template-columns: repeat(2, 1fr); }
    .metric-item {
      padding: 24px 16px;
      border-right: none;
      border-bottom: 1px solid var(--dark-3);
    }
    .cta-box { padding: 40px 24px; }
  }
</style>
